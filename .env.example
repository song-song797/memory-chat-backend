# LLM Configuration (OpenAI-compatible)
OPENAI_API_KEY=sk-example
OPENAI_BASE_URL=http://aiapi.un-net.com/v1
OPENAI_MODEL=glm-5
MEMORY_MODEL=qwen3.5-plus

# Database
DB_DRIVER=postgresql+psycopg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=llm_memory_chat
DB_USER=root
DB_PASSWORD=

# Memory
CONTEXT_WINDOW_SIZE=20
MEMORY_GLOBAL_LIMIT=4
MEMORY_PROJECT_LIMIT=6
MEMORY_CONVERSATION_LIMIT=6
MEMORY_AUTO_SUGGESTIONS_ENABLED=true
MEMORY_CONVERSATION_AUTO_ACCEPT=true
MEMORY_CONVERSATION_COMPACT_THRESHOLD=0
MEMORY_CONVERSATION_COMPACT_MAX_CHARS=3000
MEMORY_INLINE_CONFIDENCE_THRESHOLD=85
MEMORY_INLINE_IMPORTANCE_THRESHOLD=80
MEMORY_CANDIDATE_CONFIDENCE_THRESHOLD=70
MEMORY_DOCUMENTS_AI_ENABLED=true

# Application
APP_TIMEZONE=Asia/Shanghai
